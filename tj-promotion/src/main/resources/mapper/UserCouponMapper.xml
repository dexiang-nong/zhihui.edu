<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tianji.promotion.mapper.UserCouponMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.tianji.promotion.domain.po.UserCoupon">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="coupon_id" property="couponId" />
        <result column="term_begin_time" property="termBeginTime" />
        <result column="term_end_time" property="termEndTime" />
        <result column="used_time" property="usedTime" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 查询当前用户所有可用优惠卷（将用户卷ID封装到creater中） -->
    <select id="queryMyConpons"
            resultType="com.tianji.promotion.domain.po.Coupon"
            parameterType="java.lang.Long"
    >
        SELECT c.id,
               c.discount_type,
               c.`specific`,
               c.discount_value,
               c.threshold_amount,
               c.max_discount_amount,
               uc.id AS creater
        FROM user_coupon uc
                 INNER JOIN coupon c ON uc.coupon_id = c.id
        WHERE uc.user_id = #{userId}
          AND uc.status = 1
    </select>

    <!-- 查询用户卷对应的优惠卷 -->
    <select id="queryCouponByUserCouponIds" resultType="com.tianji.promotion.domain.po.Coupon">
        SELECT c.id,
               c.discount_type,
               c.`specific`,
               c.discount_value,
               c.threshold_amount,
               c.max_discount_amount,
               uc.id AS creater
        FROM user_coupon uc
                INNER JOIN coupon c ON uc.coupon_id = c.id
        WHERE uc.id IN
            <foreach item="item" collection="userCouponIds" separator="," open="(" close=")">
                #{item}
            </foreach>
        AND uc.status = #{status}
    </select>

</mapper>
